generator client {
    provider     = "prisma-client"
    output       = "../src/generated/prisma"
    moduleFormat = "cjs"
    runtime      = "nodejs"
}

datasource db {
    provider = "postgresql"
}

enum DeviceType {
    DESKTOP
    MOBILE
}

enum HealthUnitType {
    UAI
    UBS
    UBSF
    HOSPITAL
    CAPS
    CER
    COV
    CMAD
    CEREST
    LABORATORY
    OTHER
}

enum HealthCareLevel {
    PRIMARY_CARE
    URGENT_CARE
    SPECIALTY_CARE
    SUPPORT_SERVICE
}

enum HealthSector {
    CENTRAL
    EAST
    NORTH
    SOUTH
    WEST
    RURAL
}

model UserPreference {
    id                        String            @id @default(cuid())
    anonymousId               String            @unique
    neighborhood              String
    email                     String?
    notificationsEnabled      Boolean           @default(false)
    emailNotificationsEnabled Boolean           @default(false)
    pushNotificationsEnabled  Boolean           @default(false)
    deviceType                DeviceType
    createdAt                 DateTime          @default(now())
    updatedAt                 DateTime          @updatedAt
    pushSubscription          PushSubscription?

    @@index([neighborhood])
}

model HealthUnit {
    id                String          @id @default(cuid())
    name              String
    unitType          HealthUnitType
    careLevel         HealthCareLevel
    sector            HealthSector
    address           String
    neighborhood      String?
    phone             String?
    openingHours      String?
    latitude          Float?
    longitude         Float?
    officialSourceUrl String
    isActive          Boolean         @default(true)
    createdAt         DateTime        @default(now())
    updatedAt         DateTime        @updatedAt

    @@unique([name, address])
    @@index([name])
    @@index([neighborhood])
    @@index([unitType])
    @@index([careLevel])
    @@index([sector])
}

model WeatherSnapshot {
    id                                  String   @id @default(cuid())
    neighborhood                        String
    latitude                            Float
    longitude                           Float
    source                              String
    currentTemperature                  Float?
    currentRain                         Float?
    currentRelativeHumidity             Float?
    currentWeatherCode                  Int?
    todayPrecipitationProbabilityMax    Float?
    todayPrecipitationSum               Float?
    todayTemperatureMax                 Float?
    todayTemperatureMin                 Float?
    tomorrowPrecipitationProbabilityMax Float?
    tomorrowPrecipitationSum            Float?
    pastThreeDaysPrecipitationSum       Float
    preventionWindowScore               Int
    rawPayload                          Json
    fetchedAt                           DateTime @default(now())

    @@index([neighborhood])
    @@index([fetchedAt])
    @@index([neighborhood, fetchedAt])
}

model PushSubscription {
    id             String         @id @default(cuid())
    anonymousId    String         @unique
    endpoint       String         @unique
    p256dh         String
    auth           String
    userAgent      String?
    createdAt      DateTime       @default(now())
    updatedAt      DateTime       @updatedAt
    userPreference UserPreference @relation(fields: [anonymousId], references: [anonymousId], onDelete: Cascade)

    @@index([createdAt])
}
